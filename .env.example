# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (Transaction pooler)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:[password]@[host]:6379
REDIS_URL="redis://localhost:6379"

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32+ character random string used to encrypt stored API keys
# Generate: openssl rand -base64 32
ENCRYPTION_KEY="your-32-char-minimum-encryption-key-here"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# ─── YouTube OAuth (optional here — also stored via /settings page) ───────────
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
