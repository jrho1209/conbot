# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase → Connect → Transaction pooler connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ─── Trigger.dev ──────────────────────────────────────────────────────────────
# From trigger.dev dashboard → Project → API Keys
TRIGGER_SECRET_KEY="tr_dev_xxxxxxxxxxxx"
# From trigger.dev dashboard → Project → Settings → Project ID
TRIGGER_PROJECT_ID="proj_xxxxxxxxxxxx"

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32+ character random string — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="your-32-char-minimum-encryption-key-here"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# ─── YouTube OAuth (optional — also stored via /settings page) ────────────────
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
